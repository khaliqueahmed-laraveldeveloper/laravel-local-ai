{
    "name": "khaliqueahmed-laraveldeveloper/laravel-local-ai",
    "description": "A package for use llm model in laravl local.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "khaliqueahmed\\LocalAI\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "khaliqueahmed\\LocalAI\\LocalAIServiceProvider"
            ],
            "aliases": {
                "LocalAI": "khaliqueahmed\\LocalAI\\Facades\\LocalAI"
            }
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "symfony/process": "^6.0|^7.0"
    }
}